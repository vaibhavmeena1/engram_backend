{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "engram-session-start",
            "type": "command",
            "command": "ENGRAM_PLUGIN_ROOT=\"${CLAUDE_PLUGIN_ROOT}\" bash \"${CLAUDE_PLUGIN_ROOT}/scripts/session_start.sh\" 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__engram__.*|mcp__engram__.*|mcp__plugin_engram_engram__.*|mcp__plugin_engram_engram__.*",
        "hooks": [
          {
            "name": "engram-inject-repository",
            "type": "command",
            "command": "ENGRAM_PLUGIN_ROOT=\"${CLAUDE_PLUGIN_ROOT}\" python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/inject_repository_context.py\"",
            "timeout": 3
          }
        ]
      }
    ]
  }
}